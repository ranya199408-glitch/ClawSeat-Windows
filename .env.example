# Application Configuration
# Copy this file to .env and fill in your local values.
# Keep values empty or placeholder-only in this example file.

APP_NAME=clawseat
APP_ENV=development
APP_DOMAIN=<your-domain.com>

# Optional Feishu/Lark integration
# Set to true only after configuring your own Feishu/Lark application.
CLAWSEAT_FEISHU_ENABLED=false
# Legacy broadcast compatibility switch. Keep false unless you know you need it.
CLAWSEAT_ENABLE_LEGACY_FEISHU_BROADCAST=false
# Accepted values are project, user, or disabled.
FEISHU_SENDER_MODE=
FEISHU_APP_ID=<FEISHU_APP_ID>
FEISHU_OPEN_ID=<FEISHU_OPEN_ID>
FEISHU_GROUP_ID=<FEISHU_GROUP_ID>
LARK_CLI_HOME=<LARK_CLI_HOME>

# Optional OpenClaw integration
OPENCLAW_ORG_ID=<OPENCLAW_ORG_ID>
OPENCLAW_CONFIG_PATH=<OPENCLAW_CONFIG_PATH>
OPENCLAW_HOME=<OPENCLAW_HOME>
OPENCLAW_PROJECT=<OPENCLAW_PROJECT>

# ClawSeat local paths
CLAWSEAT_ROOT=<CLAWSEAT_ROOT>
CLAWSEAT_RUNTIME_ROOT=<CLAWSEAT_RUNTIME_ROOT>
CLAWSEAT_REAL_HOME=<HOME>
CLAWSEAT_PROJECT=<CLAWSEAT_PROJECT>
CLAWSEAT_WORKSPACE_ROOT=<CLAWSEAT_WORKSPACE_ROOT>
CLAWSEAT_SHARED_SECRETS_DIR=<CLAWSEAT_SHARED_SECRETS_DIR>
