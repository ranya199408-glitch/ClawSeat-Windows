.DS_Store
__pycache__/
.pytest_cache/
node_modules/
dist/
build/
.tasks/
.tmp/
generated/
*.pyc
clawseat.egg-info/

# Operator-local machine config — contains absolute paths + tenant list.
# Written/regenerated by machine_config.load_machine on first ancestor launch.
/machine.toml

# task-watch launchd runtime artifacts (logs + generated report)
/.agent/task-watch/*.log
/.agent/task-watch/latest.md

# pytest tmux verbose client logs (generated by tmux -v during tests)
tmux-client-*.log

# Internal install/ops session artifacts (never publish)
/.agent/ops/

# Public-release local/generated/private exclusions
.git/
.deps/
.venv/
venv/
.config/
.agent/ops/
docs/superpowers/
logs/
*.log
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.jks
*.map
credentials.json
service-account*.json
sessions/
secrets/
.secrets/
.claude/settings.json
